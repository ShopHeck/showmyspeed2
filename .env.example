# ── Supabase ──────────────────────────────────────────────────
# Get these from: supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Stripe ────────────────────────────────────────────────────
# Public key (used client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Netlify Functions (server-side only, NOT prefixed with VITE_) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SINGLE=price_1TDs4EGu6ZTrX6WqkfpIZbZi
STRIPE_PRICE_UNLIMITED=price_1TDs4KGu6ZTrX6WqTvWWUify

# Supabase service role key — server-side ONLY, never expose to client
# Get from: supabase.com/dashboard → Settings → API → service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
